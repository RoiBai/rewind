{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/analyze-episode.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/rewind/demo",
      "destination": "/index.html"
    },
    {
      "source": "/rewind/demo/",
      "destination": "/index.html"
    },
    {
      "source": "/rewind/demo/:path*",
      "destination": "/:path*"
    }
  ]
}

# Server-only. Add this in Vercel Project Settings -> Environment Variables.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional server model choices.
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_CLIP_MODEL=gpt-4.1-mini

# Optional. Restrict browser origins when the API is called from another site.
REWIND_ALLOWED_ORIGIN=https://www.ruiyuanbai.com

# Optional front-end base path if this app is built inside your personal site path.
VITE_BASE_PATH=/rewind/demo/
